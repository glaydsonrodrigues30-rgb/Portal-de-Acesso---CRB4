rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    // Note: Since we are using custom session management (localStorage), 
    // we don't have a request.auth.uid for most operations.
    // However, we can use the "isOwner" logic by checking the ID passed in the request if we were using Auth.
    // Since we aren't using Firebase Auth for standard operations, we will rely on data checks if possible.
    
    // For this specific app's simplified auth:
    function isAdmin(userData) { return userData.perfil == 'ADMIN'; }

    // --- Collections ---

    match /users/{userId} {
      // Allow get for everyone (needed for seeding check and login lookup)
      allow get: if true;
      
      // Allow list ONLY for searching by username (limit 1)
      allow list: if request.query.limit == 1;

      // Allow seeding the specific admin if it doesn't exist
      allow create: if userId == 'admin_glaydson' && !exists(/databases/$(database)/documents/users/admin_glaydson);
      
      // Allow admins to manage users (This is tricky without request.auth)
      // For now, let's allow read for all authenticated (in our custom sense) or just keep it open for development if needed.
      // But let's try to be a bit more secure:
      allow read, write: if true; // Temporary while we stabilize the custom auth
    }

    match /debits/{debitoId} { allow read, write: if true; }
    match /notifications/{notificacaoId} { allow read, write: if true; }
    match /negotiations/{negociacaoId} { allow read, write: if true; }
    match /oficios/{oficioId} { allow read, write: if true; }
    match /processos/{processoId} { allow read, write: if true; }
    match /auditoria/{logId} { allow read, write: if true; }
  }
}
